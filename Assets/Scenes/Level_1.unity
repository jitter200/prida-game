  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6dd324867441f684e89f4f9a5844b054, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: PRIEST
  npcPortrait: {fileID: 21300000, guid: 0c2d3988e2398934290709d30aad5854, type: 3}
  dialogueLines:
  - "\u0414\u0430 \u043F\u0440\u0435\u0431\u0443\u0434\u0435\u0442 \u0441 \u0442\u043E\u0431\u043E\u0439
    \u0441\u0432\u0435\u0442, \u0441\u0442\u0440\u0430\u043D\u043D\u0438\u043A\u2026
    \u0422\u044B \u043E\u0441\u0432\u043E\u0431\u043E\u0434\u0438\u043B \u043C\u0435\u043D\u044F
    \u0438\u0437 \u044D\u0442\u043E\u0439 \u043A\u043B\u0435\u0442\u043A\u0438, \u043A\u043E\u0433\u0434\u0430
    \u043D\u0430\u0434\u0435\u0436\u0434\u0430 \u0443\u0436\u0435 \u043F\u043E\u043A\u0438\u0434\u0430\u043B\u0430
    \u043C\u043E\u0451 \u0441\u0435\u0440\u0434\u0446\u0435."
  - "\u042F \u2014 \u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C \u0441\u0442\u0430\u0440\u043E\u0433\u043E
    \u043F\u0443\u0442\u0438. \u041C\u043D\u043E\u0433\u043E \u043B\u0435\u0442 \u044F
    \u043C\u043E\u043B\u0438\u043B\u0441\u044F, \u0447\u0442\u043E\u0431\u044B \u043A\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
    \u0441\u043C\u043E\u0433 \u043F\u0440\u043E\u0439\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435
    \u0438 \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C \u0438\u0441\u043A\u0430\u0436\u0435\u043D\u0438\u0435."
  - "\u0412\u043F\u0435\u0440\u0435\u0434\u0438 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0445\u0440\u0430\u043C. \u041D\u043E \u0435\u0433\u043E \u0432\u0440\u0430\u0442\u0430
    \u0437\u0430\u043F\u0435\u0447\u0430\u0442\u0430\u043D\u044B \u0434\u0440\u0435\u0432\u043D\u0438\u043C
    \u0437\u0430\u043C\u043A\u043E\u043C.\n\u0427\u0442\u043E\u0431\u044B \u043E\u0442\u043A\u0440\u044B\u0442\u044C
    \u0438\u0445, \u0442\u0435\u0431\u0435 \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u044F\u0442\u0441\u044F
    \u0434\u0432\u0430 \u043A\u043B\u044E\u0447\u0430."
  - "\u0411\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D\u2026
    \u0425\u0440\u0430\u043C \u043F\u0443\u0441\u043A\u0430\u0435\u0442 \u0432\u043D\u0443\u0442\u0440\u044C
    \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u0445, \u043A\u0442\u043E \u0433\u043E\u0442\u043E\u0432
    \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u0442\u044C \u0446\u0435\u043D\u0443
    \u0437\u0430 \u0438\u0441\u0442\u0438\u043D\u0443."
