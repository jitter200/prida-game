MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 151283128}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6dd324867441f684e89f4f9a5844b054, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: ARCHAEOLOGIST
  npcPortrait: {fileID: 21300000, guid: df1e21ee0b4a57b478ab3e658c11b384, type: 3}
  dialogueLines:
  - "\u0421\u043F\u0430\u0441\u0438\u0431\u043E\u2026 \u042F \u0434\u0443\u043C\u0430\u043B,
    \u0447\u0442\u043E \u0443\u0436\u0435 \u043D\u0435 \u0432\u044B\u0431\u0435\u0440\u0443\u0441\u044C
    \u0438\u0437 \u044D\u0442\u043E\u0439 \u043A\u043B\u0435\u0442\u043A\u0438."
  - "\u042F \u0430\u0440\u0445\u0435\u043E\u043B\u043E\u0433. \u041C\u043D\u043E\u0433\u043E
    \u043B\u0435\u0442 \u044F \u0438\u0441\u043A\u0430\u043B \u044D\u0442\u043E \u043C\u0435\u0441\u0442\u043E,
    \u0438 \u0442\u0435\u043F\u0435\u0440\u044C \u043F\u043E\u043D\u0438\u043C\u0430\u044E:
    \u0432\u043D\u0438\u0437\u0443 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
    \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u043E, \u0440\u0430\u0434\u0438 \u0447\u0435\u0433\u043E
    \u044F \u043F\u0440\u0438\u0448\u0451\u043B \u0441\u044E\u0434\u0430."
  - "\u041D\u043E \u044F \u043D\u0435 \u0441\u043C\u043E\u0433\u0443 \u0441\u043F\u0443\u0441\u0442\u0438\u0442\u044C\u0441\u044F\u2026
    \u0421\u0442\u0440\u0430\u0436\u0438 \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u043A\u0430\u043B\u0435\u0447\u0438\u043B\u0438
    \u043C\u0435\u043D\u044F, \u0430 \u043D\u043E\u0433\u0430 \u043F\u043E\u0447\u0442\u0438
    \u043D\u0435 \u0434\u0432\u0438\u0433\u0430\u0435\u0442\u0441\u044F."
  - "\u0412\u043D\u0438\u0437\u0443 \u0442\u0435\u0431\u044F \u0436\u0434\u0451\u0442
    \u0437\u0430\u0433\u0430\u0434\u043A\u0430. \u042F \u0443\u0432\u0435\u0440\u0435\u043D,
    \u043E\u043D\u0430 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u043F\u0443\u0442\u044C
    \u0434\u0430\u043B\u044C\u0448\u0435.\n\u0422\u043E\u043B\u044C\u043A\u043E \u0440\u0430\u0437\u0433\u0430\u0434\u043A\u0430
    \u043D\u0435 \u0437\u0434\u0435\u0441\u044C\u2026 \u0418\u0449\u0438 \u0435\u0451
    \u0432 \u0445\u0440\u0430\u043C\u0435."
  - "\u0411\u0443\u0434\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u0435\u043D.
    \u0415\u0441\u043B\u0438 \u0434\u0440\u0435\u0432\u043D\u0438\u0435 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u044B
    \u0432\u0441\u0451 \u0435\u0449\u0451 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442,
    \u043E\u043D\u0438 \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u044F\u0442 \u043E\u0448\u0438\u0431\u043A\u0438."
