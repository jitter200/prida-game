--- !u!114 &486725757
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 486725756}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6dd324867441f684e89f4f9a5844b054, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: SENSEI
  npcPortrait: {fileID: 21300000, guid: cb32c6de52eed934b83485447a30fb73, type: 3}
  dialogueLines:
  - "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C.\n\u0422\u044B
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u0441\u044F \u0441\u0440\u0435\u0434\u0438
    \u0440\u0443\u0438\u043D \u043C\u0438\u0440\u0430, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0434\u0430\u0432\u043D\u043E \u0437\u0430\u0431\u044B\u043B \u0441\u0432\u043E\u0451
    \u043F\u0440\u043E\u0448\u043B\u043E\u0435.\n\u041F\u0440\u0435\u0436\u0434\u0435
    \u0447\u0435\u043C \u0438\u0434\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435,
    \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E \u043D\u0430\u0443\u0447\u0438\u0442\u044C\u0441\u044F
    \u0432\u044B\u0436\u0438\u0432\u0430\u0442\u044C. \u0421\u043B\u0443\u0448\u0430\u0439
    \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E."
  - "\u0417\u0430\u043F\u043E\u043C\u043D\u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0435
    \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F:\nWASD \u2014 \u043F\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043D\u0438\u0435,
    \u041B\u041A\u041C \u2014 \u0430\u0442\u0430\u043A\u0430, Z \u2014 \u043F\u0430\u0440\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435,
    Ctrl \u2014 \u0440\u044B\u0432\u043E\u043A, Q \u2014 \u0441\u0443\u043F\u0435\u0440\u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C.\n\u0415\u0441\u043B\u0438
    \u0441\u0445\u0432\u0430\u0442\u0438\u0448\u044C\u0441\u044F \u0437\u0430 \u0443\u0441\u0442\u0443\u043F,
    \u043D\u0430\u0436\u043C\u0438 X, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0434\u043D\u044F\u0442\u044C\u0441\u044F,
    \u0438\u043B\u0438 S, \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u043F\u0443\u0441\u0442\u0438\u0442\u044C
    \u0435\u0433\u043E \u0438 \u0443\u043F\u0430\u0441\u0442\u044C \u0432\u043D\u0438\u0437.\n\u0414\u043B\u044F
    \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
    \u0441 \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0430\u043C\u0438, \u0434\u0432\u0435\u0440\u044F\u043C\u0438
    \u0438 \u043C\u0435\u0445\u0430\u043D\u0438\u0437\u043C\u0430\u043C\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439
    E."
  - "\u042D\u0442\u043E\u0442 \u043C\u0438\u0440 \u2014 \u043E\u0441\u043A\u043E\u043B\u043E\u043A
    \u0434\u0430\u043B\u0451\u043A\u043E\u0433\u043E \u0431\u0443\u0434\u0443\u0449\u0435\u0433\u043E,
    \u0433\u0434\u0435 \u0434\u0440\u0435\u0432\u043D\u0438\u0435 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438
    \u0434\u0430\u0432\u043D\u043E \u0441\u0442\u0430\u043B\u0438 \u043F\u043E\u0445\u043E\u0436\u0438
    \u043D\u0430 \u043C\u0430\u0433\u0438\u044E, \u0430 \u043F\u043E\u0440\u0442\u0430\u043B\u044B
    \u0441\u043E\u0435\u0434\u0438\u043D\u044F\u044E\u0442 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0443\u0446\u0435\u043B\u0435\u0432\u0448\u0438\u0435 \u0440\u0443\u0438\u043D\u044B.\n\u0418\u0441\u043A\u0430\u0436\u0435\u043D\u0438\u0435
    \u043F\u0440\u043E\u0431\u0443\u0434\u0438\u043B\u043E \u0441\u0442\u0440\u0430\u0436\u0435\u0439
    \u0438 \u0437\u0430\u043A\u0440\u044B\u043B\u043E \u043F\u0443\u0442\u044C \u0434\u0430\u043B\u044C\u0448\u0435,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E
    \u043D\u0430\u0439\u0442\u0438 \u043F\u043E\u0440\u0442\u0430\u043B, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C \u043F\u0443\u0442\u044C.\n\u041F\u043E\u043C\u043D\u0438:
    \u043A\u0430\u0436\u0434\u044B\u0439 \u043F\u043E\u0440\u0442\u0430\u043B \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u0435\u0442
    \u0442\u0435\u0431\u044F \u043A \u0442\u043E\u043C\u0443, \u043A\u0442\u043E
    \u043D\u0430\u0440\u0443\u0448\u0438\u043B \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435
    \u044D\u0442\u043E\u0433\u043E \u043C\u0438\u0440\u0430."
