  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6dd324867441f684e89f4f9a5844b054, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: KVORO
  npcPortrait: {fileID: 21300000, guid: 3081d1ddd63235d40ae47c31c42a5af8, type: 3}
  dialogueLines:
  - "\u041E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0441\u044C\u2026 \u041D\u0435
    \u043F\u043E\u0434\u043D\u0438\u043C\u0430\u0439\u0441\u044F \u0432\u044B\u0448\u0435
    \u0431\u0435\u0437 \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0438.\n\u041D\u0430\u0432\u0435\u0440\u0445\u0443
    \u0447\u0442\u043E-\u0442\u043E \u0435\u0441\u0442\u044C. \u042F \u0441\u043B\u044B\u0448\u0430\u043B
    \u0442\u044F\u0436\u0451\u043B\u044B\u0435 \u0448\u0430\u0433\u0438 \u0438 \u0441\u043A\u0440\u0435\u0436\u0435\u0442
    \u043A\u043E\u0433\u0442\u0435\u0439 \u043E \u043A\u0430\u043C\u0435\u043D\u044C."
  - "\u042D\u0442\u043E \u043D\u0435 \u043E\u0431\u044B\u0447\u043D\u044B\u0439 \u0441\u0442\u0440\u0430\u0436."
  - "\u0415\u0441\u043B\u0438 \u0432\u0441\u0451 \u0436\u0435 \u0440\u0435\u0448\u0438\u0448\u044C
    \u0438\u0434\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435 \u2014 \u0434\u0435\u0440\u0436\u0438
    \u043E\u0440\u0443\u0436\u0438\u0435 \u043D\u0430\u0433\u043E\u0442\u043E\u0432\u0435.\n\u041E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u044C
    \u0436\u0434\u0451\u0442 \u0441\u0432\u0435\u0440\u0445\u0443."
